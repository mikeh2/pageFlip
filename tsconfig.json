{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src/pf",
    "declaration": true, 
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "esnext",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/pf/**/*"],
  "exclude": ["node_modules"]
}

